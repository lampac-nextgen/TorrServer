# TorrServer Docker Compose — copy to `.env` and adjust
# cp .env.example .env

# Container image (published releases)
TORRSERVER_IMAGE=ghcr.io/yourok/torrserver:latest
TORRSERVER_CONTAINER_NAME=torrserver

# Host directory for persistent data (config, torrent cache, logs)
TORRSERVER_DATA_DIR=./data

# Web UI / API port (must match ports mapping in docker-compose.yml)
TS_PORT=8090

# Paths inside the container (defaults match Dockerfile)
TS_CONF_PATH=/opt/ts/config
TS_LOG_PATH=/opt/ts/log/torrserver.log
TS_TORR_DIR=/opt/ts/torrents

# Optional bind address inside the container
# TS_IP=0.0.0.0

# Feature flags — set to 1 to enable
TS_HTTPAUTH=0
TS_RDB=0
TS_DONTKILL=0

# TLS
# TS_EN_SSL=1
# TS_SSL_PORT=8443

# BitTorrent proxy
# TS_PROXYURL=socks5h://user:password@example.com:2080
# TS_PROXYMODE=tracker

# Go runtime (Dockerfile default)
GODEBUG=madvdontneed=1

# Local build override (docker compose -f docker-compose.yml -f docker-compose.build.yml up -d --build)
# TORRSERVER_BUILD_CONTEXT=./dist/docker
# TORRSERVER_IMAGE=torrserver:local
